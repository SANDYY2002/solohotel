// Prisma schema for SOLTERRA, using MySQL.
//
// Point DATABASE_URL at any MySQL 8+ instance — local (via Docker or a
// native install), or a managed provider (PlanetScale, Railway, AWS RDS,
// etc). See README.md for local setup and `.env.example` for the
// connection string format.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ContactStatus {
  NEW
  READ
  RESPONDED
}

enum ReservationStatus {
  HELD
  CONFIRMED
  CANCELLED
}

model ContactSubmission {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @default(now()) @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Reservation {
  id                String             @id @default(cuid())
  confirmationCode  String             @unique
  roomSlug          String
  roomName          String
  checkIn           String
  checkOut          String
  guests            Int
  promoCode         String?
  totalPriceUsd     Int
  guestName         String
  guestEmail        String
  guestPhone        String?
  specialRequests   String?            @db.Text
  status            ReservationStatus  @default(HELD)
  notes             String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @default(now()) @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([guestEmail])
}

// Lightweight audit trail for admin actions (status changes, deletions,
// content saves). There's a single shared admin password rather than
// per-user accounts, so "who" is always "Staff" — this still gives a
// record of *what* changed and *when*, which is most of the value.
model AdminActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  summary   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
}

// Single-row store for every admin-editable piece of site copy (settings,
// rooms, dining, spa, gallery, testimonials, FAQs, about). Kept as one JSON
// blob rather than fully normalized tables since it's just structured text
// and image URLs, not relational data — see src/lib/content-store.ts.
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model SiteContent {
  key       String   @id @default("site-content")
  data      Json
  updatedAt DateTime @default(now()) @updatedAt
}
