# MySQL connection string. Format:
#   mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example (matches the docker run command in README.md):
DATABASE_URL="mysql://root:password@localhost:3306/solterra"

# Password for the /admin dashboard (staff login). Change this.
ADMIN_PASSWORD="change-me"

# Random secret used to sign the admin session cookie. Generate one with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"
