# MySQL connection string. Format:
#   mysql://USER:PASSWORD@HOST:PORT/DATABASE
#
# Local example (matches the docker run command in README.md):
#   DATABASE_URL="mysql://root:password@localhost:3306/solterra"
#
# TiDB Cloud Starter example (free, MySQL-compatible, recommended for
# production on Vercel — see "Going to production" in README.md). Note the
# per-cluster username prefix and the required sslaccept=strict:
#   DATABASE_URL="mysql://<prefix>.root:<password>@gateway01.<region>.prod.aws.tidbcloud.com:4000/solterra?sslaccept=strict"
DATABASE_URL="mysql://root:password@localhost:3306/solterra"

# Password for the /admin dashboard (staff login). Change this.
ADMIN_PASSWORD="change-me"

# Random secret used to sign the admin session cookie. Generate one with:
#   openssl rand -hex 32
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"

# Enables "Upload from device" in the admin dashboard (Rooms, Gallery, Dining,
# About, Home). Create a Blob store in your Vercel project (Storage tab →
# Create Database → Blob) and it will add this automatically in production.
# For local dev, copy the token it gives you here, or run `vercel env pull`.
# Without this set, image fields still work by pasting a URL — uploads just
# return a clear error explaining it isn't configured yet.
BLOB_READ_WRITE_TOKEN=""

# Enables guest booking confirmations and staff notification emails (new
# reservation, new contact message). Sign up free at resend.com (3,000
# emails/month, no credit card) → API Keys → Create API Key → paste it here.
# Without this set, bookings and messages still work exactly as before —
# emails are just skipped, and it's logged in the Activity Log so staff
# notice if confirmations stop going out.
RESEND_API_KEY=""

# Optional. By default emails send from Resend's shared sandbox address
# (onboarding@resend.dev), which only delivers to the email on your Resend
# account — fine for testing, not for real guests. Once you verify your own
# domain in the Resend dashboard (Domains → Add Domain, then add the DNS
# records it gives you), set this to an address on it, e.g.:
#   RESEND_FROM_EMAIL="reservations@yourdomain.com"
RESEND_FROM_EMAIL=""
